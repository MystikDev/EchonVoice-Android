<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Android 11+ package visibility: declare the camera-capture intent so the
         app can resolve/launch the system camera app. Without this, TakePicture()
         throws ActivityNotFoundException on devices where the camera app isn't
         auto-visible. -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
    </queries>

    <!-- LiveKit merges in CAMERA, but Echon only does voice + view-only screen
         share (never captures the device camera). A declared-but-ungranted CAMERA
         permission makes Android reject ACTION_IMAGE_CAPTURE with a SecurityException
         (photo capture goes through the system camera app, which holds its own
         permission). Remove it: fixes the crash and shrinks the permission surface. -->
    <uses-permission android:name="android.permission.CAMERA" tools:node="remove" />

    <!-- LiveKit also merges the media-projection FGS permission + its
         ScreenCaptureService for PUBLISHING your own screen. Echon does view-only
         screen share (it only subscribes to a remote screen track, which needs no
         MediaProjection), so remove both — keeps the FGS declaration to microphone
         only and avoids declaring a screen-capture use we don't have. -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"
        tools:node="remove" />

    <!-- Camera is used opportunistically (attach a photo); not required to install. -->
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Self-update install permissions (REQUEST_INSTALL_PACKAGES,
         UPDATE_PACKAGES_WITHOUT_USER_ACTION) live in the `direct` flavor manifest
         only — Google Play prohibits self-updating, so the `play` flavor omits them. -->
    <!-- Voice (LiveKit). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Notifications: the ongoing voice-call foreground-service notification (both
         flavors) and, on `direct`, the "update ready" fallback. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".EchonApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Echon">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Echon">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Keeps the mic active while in a voice call (Android 14+ FGS type). -->
        <service
            android:name=".feature.voice.CallForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Remove LiveKit's own-screen-capture service (view-only screen share
             never starts it); pairs with removing the media-projection permission. -->
        <service
            android:name="io.livekit.android.room.track.screencapture.ScreenCaptureService"
            tools:node="remove" />

        <!-- Firebase Cloud Messaging: receives push (message/DM) notifications. -->
        <service
            android:name=".core.push.EchonMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- InstallResultReceiver (self-update) is declared in the `direct` flavor
             manifest only; the `play` flavor has no self-updater. -->

        <!-- Grants the system camera app write access to a capture-staging file
             so photos taken in-app can be attached to a message. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
