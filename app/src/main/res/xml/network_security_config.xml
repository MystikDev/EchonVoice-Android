<?xml version="1.0" encoding="utf-8"?>
<!--
  Platform-layer pinning. For the app's own OkHttp clients (REST, WebSocket,
  refresh, Coil) this mirrors the programmatic CertificatePinner (TlsPinning.kt)
  as defense-in-depth. For LiveKit (voice), which uses its own internal OkHttp
  stack, THIS config is the ONLY pin in effect — Android enforces it on every
  socket regardless of client, so it covers wss://echon-voice.com/lk. Pins the
  long-lived ISRG roots (X1 + X2) rather than rotating Let's Encrypt
  intermediates, matching the iOS client.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">echon-voice.com</domain>
        <!--
          Expiry pushed to 2028-06-01 (was 2027-01-01, which would soon stop
          enforcing pins). Both ISRG roots are pinned so one already backs up the
          other; the roots are valid into the 2030s. ROTATE this date + re-verify
          the pins before the deadline.
        -->
        <pin-set expiration="2028-06-01">
            <!-- ISRG Root X1 -->
            <pin digest="SHA-256">C5+lpZ7tcVwmwQIMcRtPbsQtWLABXhQzejna0wHFr8M=</pin>
            <!-- ISRG Root X2 -->
            <pin digest="SHA-256">diGVwiVYbubAI3RW4hB9xU8e/CH2GnkuvVFZE8zmgzI=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
